root = true

[*]
charset = utf-8
end_of_line = lf

indent_size = 2
indent_style = space

insert_final_newline = true
trim_trailing_whitespace = true

[*.{bash,sh,zsh}]
indent_size = 4
max_line_length = 80
trim_trailing_whitespace = false

[{Dockerfile,*.dockerfile}]
indent_size = 4
trim_trailing_whitespace = false

[*.go]
indent_size = unset
indent_style = tab
max_line_length = 90

[*.{json,jsonc,json5}]
indent_size = 2
max_line_length = unset

[LICENSE]
insert_final_newline = false

[{Makefile*,*.mk}]
indent_size = unset
indent_style = tab
trim_trailing_whitespace = false

[*.md]
max_line_length = 90
trim_trailing_whitespace = false
x-soft-wrap-text = true

[*.tf]
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yaml,yml}]
max_line_length = 90
